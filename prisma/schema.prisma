// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String              @id @default(cuid())
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  email                String?             @unique
  totalMinedEcho       Float               @default(0)
  totalPurchasedEcho   Float               @default(0)
  totalReferralEcho    Float               @default(0)
  totalBonusEcho       Float               @default(0)

  purchaseMultiplier   Float               @default(1)
  referralMultiplier   Float               @default(1)
  riskScore            Float               @default(0)

  referralCode         String?             @unique
  referredByUserId     String?
  referredByUser       User?               @relation("UserReferredBy", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers        User[]              @relation("UserReferredBy")

  wallet               Wallet?
  miningSession        MiningSession?
  miningHistory        MiningHistory[]
  sessions             Session[]
  purchases            Purchase[]
  ledgerEntries        LedgerEntry[]
  referralsMade        Referral[]          @relation("ReferralReferrer")
  referralsReceived    Referral[]          @relation("ReferralReferred")
  leaderboardRewards   LeaderboardReward[]
  claimAllocations     ClaimAllocation[]

  @@index([totalMinedEcho])
  @@index([totalPurchasedEcho])
  @@index([referralCode])
  @@index([riskScore])
}

model Wallet {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  address    String   @unique
  verified   Boolean  @default(false)
  verifiedAt DateTime?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WalletNonce {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  walletAddress String
  nonce         String

  @@index([walletAddress])
  @@index([nonce])
}

model MiningSession {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive      Boolean  @default(false)
  startedAt     DateTime?
  lastAccruedAt DateTime?

  baseRatePerHr Float    @default(0)
  multiplier    Float    @default(1)

  sessionMined  Float    @default(0)

  @@index([isActive])
}

model MiningHistory {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt     DateTime
  endedAt       DateTime

  baseRatePerHr Float
  multiplier    Float
  totalMined    Float

  @@index([userId])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model Purchase {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  confirmedAt   DateTime?

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletAddress String
  packageId     String
  solAmount     Float
  echoAmount    Float
  txSignature   String?  @unique
  status        String   @default("pending")

  @@index([userId])
  @@index([walletAddress])
  @@index([status])
  @@index([createdAt])
}

model LedgerEntry {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String
  amountEcho   Float
  sourceType   String?
  sourceId     String?
  metadataJson Json?

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Referral {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  qualifiedAt     DateTime?

  referrerUserId  String
  referrerUser    User     @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)

  referredUserId  String   @unique
  referredUser    User     @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  status          String   @default("pending")

  @@index([referrerUserId])
  @@index([status])
}

model LeaderboardReward {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  periodKey   String
  rank        Int
  multiplier  Float
  startsAt    DateTime
  endsAt      DateTime

  @@index([userId])
  @@index([periodKey])
  @@index([startsAt, endsAt])
}

model ClaimAllocation {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletAddress   String
  snapshotId      String
  snapshotAmount  Float
  claimableAmount Float
  claimedAmount   Float    @default(0)
  claimedAt       DateTime?

  status          String   @default("unclaimed")

  @@index([userId])
  @@index([walletAddress])
  @@index([snapshotId])
  @@index([status])
}

model DailyMetric {
  id            String   @id @default(cuid())
  date          DateTime @unique

  newWallets    Int      @default(0)
  activeMiners  Int      @default(0)
  echoMined     Float    @default(0)
  echoPurchased Float    @default(0)
  solRevenue    Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}