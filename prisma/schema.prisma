datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  email               String?  @unique

  // settled balances only
  totalMinedEcho      Float    @default(0)
  totalPurchasedEcho  Float    @default(0)
  totalReferralEcho   Float    @default(0)
  totalBonusEcho      Float    @default(0)

  // persistent account multipliers
  purchaseMultiplier  Float    @default(1)
  referralMultiplier  Float    @default(1)

  // anti-abuse / referral fields
  riskScore           Float    @default(0)
  referralCode        String?  @unique
  referredByUserId    String?

  referredBy          User?    @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers       User[]   @relation("UserReferrals")

  wallet              Wallet?
  miningSession       MiningSession?
  miningHistory       MiningHistory[]
  sessions            Session[]
  purchases           Purchase[]
  ledgerEntries       LedgerEntry[]
  leaderboardRewards  LeaderboardReward[]

  @@index([totalMinedEcho])
  @@index([totalPurchasedEcho])
  @@index([riskScore])
  @@index([referralCode])
  @@index([referredByUserId])
}

model Wallet {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  address    String   @unique
  verified   Boolean  @default(false)
  verifiedAt DateTime?

  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model WalletNonce {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  walletAddress String
  nonce         String

  @@index([walletAddress])
  @@index([nonce])
  @@index([createdAt])
}

model MiningSession {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive              Boolean  @default(false)

  startedAt             DateTime?
  endsAt                DateTime?

  // projected-session mining model
  baseDailyEcho         Float    @default(0)

  // permanent session multiplier stack (streak + purchase + referral + leaderboard)
  baseSessionMultiplier Float    @default(1)

  // temporary boost multiplier stack
  boostMultiplier       Float    @default(1)
  boostExpiresAt        DateTime?

  // live effective multiplier + rate
  currentMultiplier     Float    @default(1)
  currentRatePerSec     Float    @default(0)

  // checkpointed accrual
  earnedEchoSnapshot    Float    @default(0)
  lastRateChangeAt      DateTime?

  // total projected payout from current point forward
  projectedTotalEcho    Float    @default(0)

  // convenience field for UI compatibility
  sessionMined          Float    @default(0)

  @@index([isActive])
  @@index([startedAt])
  @@index([endsAt])
  @@index([boostExpiresAt])
}

model MiningHistory {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt     DateTime
  endedAt       DateTime

  // historical record of the settled session
  baseRatePerHr Float
  multiplier    Float
  totalMined    Float

  @@index([userId])
  @@index([createdAt])
  @@index([endedAt])
}

model Session {
  id         String   @id
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  revokedAt  DateTime?

  @@index([userId])
  @@index([expiresAt])
}

model Purchase {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletAddress String
  packageId     String

  solAmount     Float
  echoAmount    Float

  status        String   @default("pending")
  txSignature   String?  @unique
  confirmedAt   DateTime?

  @@index([userId])
  @@index([walletAddress])
  @@index([packageId])
  @@index([status])
  @@index([createdAt])
}

model LedgerEntry {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         String
  amountEcho   Float

  sourceType   String?
  sourceId     String?

  metadataJson Json?

  @@index([userId])
  @@index([type])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model LeaderboardReward {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  rank         Int
  multiplier   Float    @default(1)
  startsAt     DateTime
  endsAt       DateTime

  @@index([userId])
  @@index([startsAt, endsAt])
  @@index([rank])
}