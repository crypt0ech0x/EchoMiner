// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==============================
// USER
// ==============================
model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email String? @unique

  // Server-truth totals
  totalMinedEcho     Float @default(0)
  totalPurchasedEcho Float @default(0)

  wallet        Wallet?
  miningSession MiningSession?
  miningHistory MiningHistory[]
  sessions      Session[]
  purchases     Purchase[]

  @@index([totalMinedEcho])
  @@index([totalPurchasedEcho])
}

// ==============================
// WALLET (1 per user)
// ==============================
model Wallet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  address    String    @unique
  verified   Boolean   @default(false)
  verifiedAt DateTime?

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ==============================
// WALLET NONCE (signature challenge)
// ==============================
model WalletNonce {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  walletAddress String
  nonce         String

  @@index([walletAddress])
  @@index([nonce])
}

// ==============================
// ACTIVE MINING SESSION (1 per user)
// ==============================
model MiningSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive Boolean @default(false)

  startedAt     DateTime?
  lastAccruedAt DateTime?

  baseRatePerHr Float @default(0)
  multiplier    Float @default(1)

  sessionMined Float @default(0)

  @@index([isActive])
}

// ==============================
// MINING HISTORY (AUDIT LOG)
// ==============================
model MiningHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt DateTime
  endedAt   DateTime

  baseRatePerHr Float
  multiplier    Float
  totalMined    Float

  @@index([userId])
  @@index([createdAt])
}

// ==============================
// PURCHASES (STORE)
// ==============================
model Purchase {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // identify what was bought
  itemId String

  // store totals in a consistent unit (echo)
  echoAmount Float @default(0)

  // optional money metadata
  currency   String? 
  priceCents Int?

  // stripe metadata (or mock session id)
  providerSessionId String? @unique
  status            String  @default("paid")

  @@index([userId])
  @@index([createdAt])
  @@index([itemId])
}

// ==============================
// AUTH SESSION COOKIE
// ==============================
model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  revokedAt DateTime?

  @@index([userId])
  @@index([expiresAt])
}