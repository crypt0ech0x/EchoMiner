generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // change to mysql if needed
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // --- Mining totals ---
  totalMinedEcho    Float    @default(0)

  // --- Optional profile fields ---
  email             String?  @unique
  emailVerified     Boolean  @default(false)
  pfpUrl            String?

  // --- Referral ---
  referralCode      String   @unique @default(cuid())
  referredById      String?
  referredBy        User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals         User[]   @relation("UserReferrals")

  // --- Admin ---
  isAdmin           Boolean  @default(false)

  // --- Relations ---
  wallet            Wallet?
  sessions          Session[]
  miningSession     MiningSession?
  miningHistory     MiningHistory[]
  purchases         Purchase[]
}

model Wallet {
  id          String   @id @default(cuid())
  address     String   @unique
  verified    Boolean  @default(false)
  verifiedAt  DateTime?
  nonce       String?  // for signature verification

  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
}

model Session {
  id         String   @id
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MiningSession {
  id             String   @id @default(cuid())
  userId         String   @unique

  isActive       Boolean  @default(false)

  startedAt      DateTime?
  lastAccruedAt  DateTime?

  baseRatePerHr  Float    @default(0)
  multiplier     Float    @default(1)

  sessionMined   Float    @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
}

model MiningHistory {
  id            String   @id @default(cuid())
  userId        String

  startedAt     DateTime
  endedAt       DateTime

  baseRatePerHr Float
  multiplier    Float
  totalMined    Float

  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String

  stripeId     String?  @unique
  itemId       String
  amount       Float
  multiplier   Float?
  durationDays Int?

  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}